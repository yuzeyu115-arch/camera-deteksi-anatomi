function updateStatus(message, isError = false) {
  statusElement.textContent = message;
  statusElement.style.color = isError ? '#ff8080' : '#ffffff';
  console.log('[STATUS]', message);
}

function syncPatientSummary() {
  if (summaryTherapy) summaryTherapy.textContent = therapyAction?.value || '-';
  if (summaryResult) summaryResult.textContent = therapyResult?.value || '-';
  if (summaryJoint) summaryJoint.textContent = jointMovement?.value || '-';
  updateSessionResult(null);
}

function updateSessionResult(percent) {
  const value = Number.isFinite(percent) ? percent : null;
  let status = 'Menunggu';
  let recommendation = 'Tunggu hasil deteksi.';
  let accuracyText = '--';

  if (value !== null) {
    const safePercent = Math.min(100, Math.max(0, value));
    accuracyText = `${safePercent.toFixed(1)}%`;
    if (safePercent >= similarityThreshold) {
      status = 'Bagus';
      recommendation = 'Lanjutkan sesi dan catat hasil terapi.';
    } else if (safePercent >= similarityThreshold * 0.8) {
      status = 'Cukup';
      recommendation = 'Ulangi gerakan dengan fokus pada sendi yang dipantau.';
    } else {
      status = 'Perlu Perbaikan';
      recommendation = 'Ulangi sesi dengan referensi tambahan atau koreksi postur.';
    }
  }

  if (sessionStatus) sessionStatus.textContent = status;
  if (sessionAccuracy) sessionAccuracy.textContent = accuracyText;
  if (sessionRecommendation) sessionRecommendation.textContent = recommendation;
  if (sessionAction) sessionAction.textContent = therapyAction?.value || '-';
}

function setButtons() {
  if (startBtn) startBtn.textContent = isRunning ? 'Jeda' : 'Mulai';
  if (stopBtn) stopBtn.disabled = !isRunning;
  if (startBtnSecondary) startBtnSecondary.textContent = isRunning ? 'Jeda' : '▶️ Mulai';
  if (stopBtnSecondary) stopBtnSecondary.disabled = !isRunning;
}

async function getCameraPermissionState() {
  if (!navigator.permissions || !navigator.permissions.query) return 'unknown';
  try {
    const permission = await navigator.permissions.query({ name: 'camera' });
    return permission.state;
  } catch (error) {
    console.warn('Permission API tidak tersedia untuk camera', error);
    return 'unknown';
  }
}

let poseBusy = false;
let frameCounter = 0;
let lastDrawTime = Date.now();
let lastPoseSendTime = Date.now();
let drawInterval = 40; // Target ~25fps for drawing (smoother visuals)
let poseSendInterval = /Mobi|Android|iPhone|iPad|iPod/i.test(navigator.userAgent) || window.innerWidth <= 768 ? 140 : 100; // pose processing frequency (reduced rate in emergency)
let computeCounter = 0; // Throttle heavy computations
let cachedRefDistances = null;
let cachedLiveDistances = null;
let cachedSimilarity = 0;
let lastDrawnLandmarks = null;
const smoothingAlpha = 0.35; // 0..1, lower = more responsive, less lag
let latestRawLandmarks = null; // store raw landmarks for accuracy computations
let lastLabelDrawTime = 0;
const labelDrawIntervalMs = 1000; // draw textual labels at most once per second
let lastOnResultsAt = 0;
let poseWatchdogId = null;
let lastComputeAt = 0;
// Hybrid accuracy: compute from raw landmarks while drawing uses smoothed landmarks
window.realtimeAccuracy = true; // default: compute accuracy from raw (more responsive)
// Do not show debug telemetry UI by default
// Enable debug telemetry temporarily to diagnose drawing/accuracy issues
// Enable debug telemetry by default to aid visibility when recovering
window.showDebugTelemetry = true;
// Emergency mode off by default for stability
window.emergencyMode = false;

window.setRealtimeAccuracy = function (enabled) {
  window.realtimeAccuracy = !!enabled;
};

// Force unmirror when drawing so overlay aligns with user (default: true)
window.forceUnmirror = true;

// TEMP DEBUG: simple mode to bypass smoothing and use raw landmarks for both drawing and accuracy
// default to simple mode so visuals map directly to raw landmarks (less smoothing complexity)
window.debugSimpleMode = true;

function startLiveProcessing() {
  if (!isRunning) return;
  
  const now = Date.now();

  // Send pose frame for processing at a lower cadence to reduce CPU load
  if (pose && typeof pose.send === 'function' && videoElement.readyState >= 2) {
    if (!poseBusy && now - lastPoseSendTime >= poseSendInterval) {
      poseBusy = true;
      lastPoseSendTime = now;
      if (poseTimeoutId) {
        clearTimeout(poseTimeoutId);
      }
      poseTimeoutId = window.setTimeout(() => {
        poseBusy = false;
        poseTimeoutId = null;
      }, 180);
      
      try {
        console.log('sending pose frame at', new Date().toISOString());
        pose.send({ image: videoElement });
      } catch (error) {
        console.warn('pose.send failed', error);
        poseBusy = false;
        if (poseTimeoutId) {
          clearTimeout(poseTimeoutId);
          poseTimeoutId = null;
        }
      }
    }
  }
  
  // Draw frame at controlled rate (throttled)
  if (now - lastDrawTime >= drawInterval) {
    drawVideoFrame();
    lastDrawTime = now;
  }
  
  // Continue animation loop - fast as possible
  animationFrameId = requestAnimationFrame(startLiveProcessing);
}

// Fallback sender (ensures pose receives frames even if RAF throttled)
let poseSenderIntervalId = null;

function drawVideoFrame() {
  if (!isRunning || !videoElement || !canvasElement || !canvasCtx) return;

  try {
    if (videoElement.readyState < 2 || !videoElement.videoWidth || !videoElement.videoHeight) return;

    const maxDisplayWidth = /Mobi|Android|iPhone|iPad|iPod/i.test(navigator.userAgent) || window.innerWidth <= 768 ? 640 : 960;
    const targetWidth = Math.min(videoElement.videoWidth, maxDisplayWidth);
    const targetHeight = Math.round(targetWidth * (videoElement.videoHeight / videoElement.videoWidth));

    if (canvasElement.width !== targetWidth || canvasElement.height !== targetHeight) {
      canvasElement.width = targetWidth;
      canvasElement.height = targetHeight;
    }

    canvasCtx.setTransform(1, 0, 0, 1, 0, 0);
    canvasCtx.clearRect(0, 0, canvasElement.width, canvasElement.height);
    // Optionally unmirror the video when drawing so overlays align with user
    if (window.forceUnmirror) {
      canvasCtx.save();
      canvasCtx.translate(canvasElement.width, 0);
      canvasCtx.scale(-1, 1);
      canvasCtx.drawImage(videoElement, 0, 0, targetWidth, targetHeight);
      canvasCtx.restore();
    } else {
      canvasCtx.drawImage(videoElement, 0, 0, targetWidth, targetHeight);
    }

    // Draw overlays (reference + live). In emergency mode use lightweight manual drawing.
    if (referenceLandmarks?.length > 0) {
      // reference overlay is subtle; use manual lightweight lines in emergency
      if (window.emergencyMode) {
        drawNerveLines(referenceLandmarks);
      } else {
        drawReferenceOverlay(referenceLandmarks);
      }
    }

    // Interpolate/smooth latestPoseLandmarks for visuals
    const smoothed = interpolateLandmarks(latestPoseLandmarks, lastDrawnLandmarks, smoothingAlpha);
    if (smoothed && smoothed.length > 0) {
      if (window.emergencyMode) {
        // manual lightweight draw: connections + small points
        drawNerveLines(smoothed);
        for (let i = 0; i < smoothed.length; i++) {
          const lm = smoothed[i];
          if (!lm) continue;
          const p = toCanvasPoint(lm);
          canvasCtx.fillStyle = '#ff4d6d';
          canvasCtx.beginPath();
          canvasCtx.arc(p.x, p.y, 3, 0, Math.PI * 2);
          canvasCtx.fill();
        }
      } else {
        drawPoseOverlay(smoothed);
      }
      lastDrawnLandmarks = smoothed;
    }
  } catch (error) {
    console.warn('drawVideoFrame error:', error);
  }
}

// Interpolate between previous landmarks and current ones to produce smooth motion
function interpolateLandmarks(current, previous, alpha) {
  if (!current) return previous || null;
  if (!previous) return current.map((p) => ({ x: p.x, y: p.y, z: p.z }));
  const out = new Array(current.length);
  for (let i = 0; i < current.length; i++) {
    const c = current[i] || { x: 0.5, y: 0.5, z: 0 };
    const p = previous[i] || c;
    out[i] = {
      x: p.x * alpha + c.x * (1 - alpha),
      y: p.y * alpha + c.y * (1 - alpha),
      z: p.z * alpha + c.z * (1 - alpha)
    };
  }
  return out;
}

function prepareVideoElement() {
  if (!videoElement) return;
  videoElement.setAttribute('playsinline', 'true');
  videoElement.setAttribute('autoplay', 'true');
  videoElement.setAttribute('muted', 'true');
  videoElement.playsInline = true;
  videoElement.muted = true;
  videoElement.style.transform = 'scaleX(1)';
  if (canvasElement) canvasElement.style.transform = 'scaleX(1)';
}

function ensureDebugTelemetry() {
  if (document.getElementById('debugTelemetry')) return;
  const d = document.createElement('div');
  d.id = 'debugTelemetry';
  d.style.cssText = 'position:fixed;right:12px;bottom:12px;background:#111;color:#fff;padding:8px 10px;border-radius:8px;font-size:12px;z-index:9999;opacity:0.95;';
  d.innerHTML = `
    <div id="dbgText">debug telemetry</div>
    <div style="margin-top:6px;display:flex;gap:6px;">
      <button id="dbgToggleSimple" style="font-size:11px;padding:6px;border-radius:6px;">Simple: ${window.debugSimpleMode ? 'ON' : 'OFF'}</button>
      <button id="dbgToggleRealtime" style="font-size:11px;padding:6px;border-radius:6px;">Realtime: ${window.realtimeAccuracy ? 'ON' : 'OFF'}</button>
    </div>
  `;
  document.body.appendChild(d);
  // Attach handlers
  document.getElementById('dbgToggleSimple').addEventListener('click', () => {
    window.debugSimpleMode = !window.debugSimpleMode;
    document.getElementById('dbgToggleSimple').textContent = `Simple: ${window.debugSimpleMode ? 'ON' : 'OFF'}`;
  });
  document.getElementById('dbgToggleRealtime').addEventListener('click', () => {
    window.realtimeAccuracy = !window.realtimeAccuracy;
    document.getElementById('dbgToggleRealtime').textContent = `Realtime: ${window.realtimeAccuracy ? 'ON' : 'OFF'}`;
  });
}

async function getCameraStream() {
  if (!navigator.mediaDevices || !navigator.mediaDevices.getUserMedia) {
    throw new Error('Browser tidak mendukung akses kamera.');
  }

  const isMobile = /Mobi|Android|iPhone|iPad|iPod/i.test(navigator.userAgent) || window.innerWidth <= 768;
  const targetWidth = isMobile ? { ideal: 640 } : { ideal: 800 };
  const targetHeight = isMobile ? { ideal: 480 } : { ideal: 600 };

  const constraintSets = [
    {
      video: {
        facingMode: { ideal: 'user' },
        width: targetWidth,
        height: targetHeight,
        frameRate: { ideal: 15, max: 20 }
      }
    },
    {
      video: {
        facingMode: 'user',
        width: { ideal: 480 },
        height: { ideal: 360 },
        frameRate: { ideal: 15, max: 20 }
      }
    },
    {
      video: {
        facingMode: { ideal: 'environment' },
        width: targetWidth,
        height: targetHeight,
        frameRate: { ideal: 15, max: 20 }
      }
    },
    { video: true }
  ];

  let lastError = null;
  for (const constraints of constraintSets) {
    try {
      return await navigator.mediaDevices.getUserMedia(constraints);
    } catch (error) {
      lastError = error;
      console.warn('Kunci kamera gagal, mencoba fallback:', error);
    }
  }

  throw lastError || new Error('Tidak bisa mendapatkan akses kamera.');
}

